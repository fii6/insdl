# Optional manual cookie fallback.
# Prefer local Chromium login-state decryption when possible.
# Example:
# INSDL_COOKIE="sessionid=...; csrftoken=..."
# or
# INSDL_COOKIE_STRING="sessionid=...; csrftoken=..."

# Optional Chromium lookup hints:
# INSDL_BROWSER=chromium
# INSDL_CHROME_PROFILE=Default
